# Copy this file to ".env" and fill in values. The .env file is git-ignored.

# --- Natural-language layer -------------------------------------------------
# Which LLM provider: "openai" (default) | "anthropic" | "genai-hub".
# With the chosen provider not ready, the app still works via a keyword fallback.
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (only used if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# SAP Generative AI Hub (only used if LLM_PROVIDER=genai-hub) — the compliant,
# SAP-native option for HR/PII. Requires: npm i @sap-ai-sdk/orchestration
# Creds: on BTP bind an `aicore` service; locally set AICORE_SERVICE_KEY to the
# AI Core service key JSON (as a single-line string).
GENAI_MODEL=gpt-4o
AICORE_SERVICE_KEY=

# --- SuccessFactors data source --------------------------------------------
# Choose one:
#   mock    = canned data (default; no SAP needed)
#   sandbox = public Business Accelerator Hub sandbox (real API shape, APIKey)
#   real    = a real SF tenant via a BTP Destination (OAuth2 SAML Bearer)
SF_MODE=mock

# Which OData entity holds the leave/time-account data. Confirm via "Try Out"
# on the hub, or your tenant's $metadata. Common: TimeAccount.
SF_ENTITY=TimeAccount

# -- sandbox mode --
# Your Business Accelerator Hub API key (api.sap.com -> any SF API -> Show API Key).
# Treat as a secret. Sandbox is read-only demo data.
SF_API_KEY=
SF_SANDBOX_URL=https://sandbox.api.sap.com/successfactors/odata/v2
# Optional: a real sandbox userId to filter by. Leave blank to just see sample rows.
SF_USER_ID=

# -- real mode --
SF_DESTINATION=SF_TIMEOFF

# Local-dev only: which user the chat acts as until XSUAA login is wired up.
MOCK_USER_ID=jdoe
